@page
@model IndexModel
@{
    ViewData["Title"] = "Premier League Management";
}

<section class="league-hero">
    <div>
        <p class="eyebrow">English Premier League API</p>
        <h1>Premier League Management</h1>
        <p class="hero-copy">ASP.NET Core 8 Web API with SQL Server, EF Core, Identity, services, seeded data, and AJAX dashboard.</p>
    </div>
    <div class="hero-badge">
        <span>Season</span>
        <strong>2025/26</strong>
    </div>
</section>

<section class="metric-grid" aria-label="League summary">
    <div class="metric">
        <span>Clubs</span>
        <strong id="clubsMetric">0</strong>
    </div>
    <div class="metric">
        <span>Players</span>
        <strong id="playersMetric">0</strong>
    </div>
    <div class="metric">
        <span>Matches</span>
        <strong id="matchesMetric">0</strong>
    </div>
    <div class="metric">
        <span>Current Leader</span>
        <strong id="leaderMetric">Loading</strong>
    </div>
</section>

<section class="snapshot-strip" aria-label="Season snapshot">
    <div>
        <span>Snapshot</span>
        <strong>Round 36 of 38</strong>
    </div>
    <div>
        <span>Remaining</span>
        <strong>20 fixtures</strong>
    </div>
    <div>
        <span>Title Race</span>
        <strong>Two weeks left</strong>
    </div>
</section>

<section class="dashboard-actions" aria-label="Main sections">
    <a class="action-card" asp-page="/Standings">
        <span>League Table</span>
        <strong>Open Standings</strong>
    </a>
    <a class="action-card" asp-page="/Clubs">
        <span>CRUD Resource</span>
        <strong>Open Clubs</strong>
    </a>
    <a class="action-card" asp-page="/Players">
        <span>Player Statistics</span>
        <strong>Open Players</strong>
    </a>
    <a class="action-card" asp-page="/Matches">
        <span>Match Console</span>
        <strong>Open Matches</strong>
    </a>
    <a class="action-card" asp-page="/Api">
        <span>Project Defense</span>
        <strong>Open API Info</strong>
    </a>
</section>

<section class="management-grid dashboard-preview">
    <div class="panel table-panel">
        <div class="section-title">
            <div>
                <p class="eyebrow">Loaded With Fetch</p>
                <h2>League Standings</h2>
            </div>
            <a class="text-link" asp-page="/Standings">View all</a>
        </div>
        <div class="table-responsive">
            <table class="league-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Club</th>
                        <th>P</th>
                        <th>W</th>
                        <th>D</th>
                        <th>L</th>
                        <th>GF</th>
                        <th>GA</th>
                        <th>GD</th>
                        <th>Pts</th>
                        <th>Form</th>
                    </tr>
                </thead>
                <tbody id="standingsBody"></tbody>
            </table>
        </div>
    </div>

    <aside class="panel">
        <div class="section-title">
            <div>
                <p class="eyebrow">API Console</p>
                <h2>Matches</h2>
            </div>
            <a class="text-link" asp-page="/Matches">View all</a>
        </div>
        <div id="matchesList" class="recent-results"></div>
    </aside>
</section>
