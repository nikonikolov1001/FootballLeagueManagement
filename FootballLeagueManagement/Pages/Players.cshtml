@page
@{
    ViewData["Title"] = "Players";
}

<section class="page-heading">
    <p class="eyebrow">Player Statistics</p>
    <h1>Premier League Players</h1>
    <p>Review appearances, goals, assists, and season ratings for key players.</p>
</section>

<section class="toolbar-panel player-toolbar" aria-label="Player controls">
    <div class="control-field">
        <label for="playerSearch">Search players</label>
        <input id="playerSearch" type="search" placeholder="Player, club, or position" autocomplete="off" />
    </div>
    <div class="control-field">
        <label for="playerSort">Sort by</label>
        <select id="playerSort">
            <option value="goals">Goals</option>
            <option value="assists">Assists</option>
            <option value="rating">Rating</option>
            <option value="appearances">Appearances</option>
            <option value="name">Name</option>
        </select>
    </div>
    <div id="apiStatus" class="api-status">Loading players</div>
</section>

<section class="metric-grid" aria-label="Player summary">
    <div class="metric">
        <span>Total Players</span>
        <strong id="playerCountMetric">0</strong>
    </div>
    <div class="metric">
        <span>Top Scorer</span>
        <strong id="topScorerMetric">Loading</strong>
    </div>
    <div class="metric">
        <span>Most Assists</span>
        <strong id="topAssistsMetric">Loading</strong>
    </div>
    <div class="metric">
        <span>Best Rating</span>
        <strong id="topRatingMetric">Loading</strong>
    </div>
</section>

<section class="panel">
    <div class="section-title">
        <div>
            <p class="eyebrow">Two Weeks Before Final Day</p>
            <h2>Player Statistics Table</h2>
        </div>
    </div>
    <div class="table-responsive">
        <table class="league-table player-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Player</th>
                    <th>Club</th>
                    <th>Pos</th>
                    <th>Apps</th>
                    <th>Goals</th>
                    <th>Assists</th>
                    <th>Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="playersBody"></tbody>
        </table>
    </div>
</section>

<section class="panel admin-panel">
    <div class="section-title">
        <div>
            <p class="eyebrow">Administrator</p>
            <h2 id="playerFormTitle">Add Player</h2>
        </div>
        <button id="playerResetButton" type="button" class="secondary-button">New</button>
    </div>
    <form id="playerForm" class="admin-form">
        <input id="playerId" type="hidden" />
        <div class="control-field">
            <label for="playerFullName">Full name</label>
            <input id="playerFullName" name="fullName" type="text" maxlength="100" required />
        </div>
        <div class="control-field">
            <label for="playerPosition">Position</label>
            <input id="playerPosition" name="position" type="text" maxlength="40" required />
        </div>
        <div class="control-field">
            <label for="playerShirtNumber">Shirt number</label>
            <input id="playerShirtNumber" name="shirtNumber" type="number" min="1" max="99" required />
        </div>
        <div class="control-field">
            <label for="playerClubId">Club</label>
            <select id="playerClubId" name="clubId" required></select>
        </div>
        <button type="submit" class="primary-button">Save Player</button>
        <div id="playerAdminStatus" class="api-status">Login as admin to save changes</div>
    </form>
</section>
